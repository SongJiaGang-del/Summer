export type Song = {
	title : string,
	artist : string,
	cover : string,
	fallbackImage : string,
	audioUrl : string,
	moodId : string,
	lyrics : string[],
	/** 每行歌词出现时间（秒），与 lyrics 严格并行；为空表示无时间轴（纯音乐/上传歌），退回按进度线性显示 */
	lyricTimes : number[],
	/** 时长（秒），0 表示未知（通常是远程示例曲，按播放时再读 duration） */
	duration : number
}

export type UserSongInput = {
	title : string,
	audioUrl : string
}

export type Mood = {
	id : string,
	color : string,
	bg : string,
	iconName : string
}

export type SceneTemplate = {
	id : string,
	name : string,
	image : string,
	fallbackImage : string,
	moodId : string,
	desc : string,
	narrative : string,
	suggestedHour : string,
	songIndices : number[]
}

export type Category = SceneTemplate

export type DnaItem = {
	name : string,
	percent : number,
	color : string
}

export type TopSongItem = {
	title : string,
	count : number
}

export type SpiritAnimal = {
	name : string,
	desc : string,
	color : string
}

export type Bottle = {
	id : number,
	message : string,
	songTitle : string,
	createdAt : number,
	replies : string[]
}

export type NavItem = {
	id : string,
	name : string,
	iconName : string
}

export type PlayMode = 'sequence' | 'repeat-one' | 'shuffle'

