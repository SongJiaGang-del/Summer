function isPlayableUserSongPath(path : string) : boolean {
	return !path.startsWith('content://')
}

function loadUserSongsTyped() : Song[] {
	const raw = loadStr(K.USER_SONGS, '')
	if (raw == '') return [] as Song[]
	try {
		const arr = JSON.parseArray<Song>(raw)
		if (arr == null) return [] as Song[]
		const filtered = arr!.filter((song : Song) : boolean => isPlayableUserSongPath(song.audioUrl))
		if (filtered.length != arr!.length) saveJson(K.USER_SONGS, filtered)
		return filtered
	} catch (e) {
		return [] as Song[]
	}
}

export const userSongs = ref<Song[]> (loadUserSongsTyped())

function rebuildPlaylist() : Song[] {
	const list : Song[] = [] as Song[]
	basePlaylist.forEach((song : Song) => { list.push(song) })
	userSongs.value.forEach((song : Song) => { list.push(song) })
	return list
}

export const playlist = ref<Song[]> (rebuildPlaylist())

function saveUserSongs() {
	saveJson(K.USER_SONGS, userSongs.value)
	playlist.value = rebuildPlaylist()
}

function normalizeUserSongTitle(name : string) : string {
	let title = name.trim()
	const dot = title.lastIndexOf('.')
	if (dot > 0) title = title.substring(0, dot)
	if (title == '') title = '我的音乐'
	if (title.length > 40) title = title.substring(0, 40)
	return title
}

