/**
 * Bottle 必须用 JSON.parseArray<Bottle> 真类型化，
 * 运行时仍是 UTSReactiveJSONObject，后续 map((b : Bottle)) 触发真转型时崩溃。
 * 用 uni-app x 的 JSON.parseArray<Bottle> 做真正的类型化解析。
 */
function loadBottlesTyped() : Bottle[] {
	const raw = loadStr(K.BOTTLES, '')
	if (raw == '') return makeDefaultBottles()
	try {
		const arr = JSON.parseArray<Bottle>(raw)
		if (arr == null || arr.length == 0) return makeDefaultBottles()
		return arr
	} catch (e) {
		return makeDefaultBottles()
	}
}

export const bottles = ref<Bottle[]> (loadBottlesTyped())

function normalizeBottle(b : Bottle) : Bottle {
	const replies = b.replies == null ? [] as string[] : b.replies
	const songTitle = b.songTitle == null || b.songTitle == '' ? '未知曲目' : b.songTitle
	const createdAt = b.createdAt <= 0 ? Date.now() : b.createdAt
	return {
		id: b.id,
		message: b.message,
		songTitle: songTitle,
		createdAt: createdAt,
		replies: replies
	}
}

function normalizeStoredBottles() {
	const arr = bottles.value.map((b : Bottle) : Bottle => normalizeBottle(b))
	bottles.value = arr
	saveBottles()
}

function saveBottles() {
	saveJson(K.BOTTLES, bottles.value)
}

normalizeStoredBottles()

function normalizeBottleText(text : string) : string {
	let value = text.trim()
	if (value.length > 80) value = value.substring(0, 80)
	return value
}

function nextBottleId() : number {
	let maxId = 0
	bottles.value.forEach((b : Bottle) => {
		if (b.id > maxId) maxId = b.id
	})
	return maxId + 1
}

/* 启动时按时段推荐默认 mood，再被持久化覆盖 */
function defaultMoodByTime() : string {
	const h = new Date().getHours()
	if (h >= 5 && h < 11) return 'sea-salt'    // 清晨
	if (h >= 17 && h < 20) return 'strawberry' // 黄昏
	if (h >= 20 || h < 5) return 'mint'        // 夜晚
	return 'sea-salt'
}

export type PlayerState = {
	isPlaying : boolean,
	progress : number,         // 0-100
	currentTime : number,      // 秒，当前播放位置（用于歌词时间轴同步）
	duration : number,         // 秒
	volume : number,           // 0-1
	moodId : string,
	currentSongIndex : number,
	activePageIndex : number,
	activeBottle : Bottle | null,
	autoPlayNext : boolean,
	playMode : PlayMode,
	audioLoading : boolean,
	audioErrorMessage : string
}

const initialPlayerState : PlayerState = {
	isPlaying: false,
	progress: 0,                // 启动不恢复进度，跟着音频实际位置走
	currentTime: 0,
	duration: 0,
	volume: loadNum(K.VOLUME, 0.7),
	moodId: loadStr(K.MOOD, defaultMoodByTime()),
	currentSongIndex: loadInt(K.SONG_INDEX, 0),
	activePageIndex: 0,
	activeBottle: null,
	autoPlayNext: loadStr(K.AUTO_NEXT, '1') == '1',
	playMode: normalizePlayMode(loadStr(K.PLAY_MODE, 'sequence')),
	audioLoading: false,
	audioErrorMessage: ''
}

export const state = reactive<PlayerState>(initialPlayerState)
if (state.currentSongIndex < 0 || state.currentSongIndex >= playlist.value.length) {
	state.currentSongIndex = 0
	saveNum(K.SONG_INDEX, 0)
}

/** 最近播放历史（最多 30 条 song.title） */
export const recents = ref<string[]> (loadArray<string>(K.RECENTS, [] as string[]))

function pushRecent(title : string) {
	const arr = recents.value.filter((t : string) : boolean => t != title)
	arr.unshift(title)
	if (arr.length > 30) arr.length = 30
	recents.value = arr
	saveJson(K.RECENTS, arr)
}

/* 防御：playlist 空数组或越界时返回占位歌曲 */
const fallbackSong : Song = {
	title: '未知曲目',
	artist: '—',
	cover: '',
	fallbackImage: '/static/images/fallback-sea.svg',
	audioUrl: '',
	moodId: 'sea-salt',
	lyrics: ['等一首歌漂过来', '夏天还很长', '夏夜会有答案'],
	lyricTimes: [] as number[],
	duration: 0
}

export const currentSong = computed<Song> (() : Song => {
	return safeGetSong(state.currentSongIndex)
})

function hasHanText(text : string) : boolean {
	for (let i = 0; i < text.length; i++) {
		const code = text.charCodeAt(i)
		if (code == null) continue
		if (code >= 0x4e00 && code <= 0x9fff) return true
	}
	return false
}

function isBilingualPairStart(lines : string[], start : number, count : number) : boolean {
	if (start < 0 || start + 1 >= count) return false
	return !hasHanText(lines[start]) && hasHanText(lines[start + 1])
}

function lyricGroupStartForIndex(lines : string[], index : number, count : number) : number {
	if (index > 0 && hasHanText(lines[index]) && !hasHanText(lines[index - 1])) return index - 1
	return index
}

function nextLyricGroupStart(lines : string[], start : number, count : number) : number {
	return start + (isBilingualPairStart(lines, start, count) ? 2 : 1)
}

function timedLyricIndex(lines : string[], times : number[], total : number, currentTime : number, duration : number) : number {
	const count = Math.min(times.length, total)
	if (count <= 0) return 0
	let idx = 0
	let i = 0
	while (i < count) {
		if (times[i] <= currentTime) idx = i
		else break
		i = nextLyricGroupStart(lines, i, count)
	}
	return lyricGroupStartForIndex(lines, idx, count)
}

function lyricSeekTime(song : Song, index : number, duration : number) : number {
	const times = song.lyricTimes
	const count = Math.min(times.length, song.lyrics.length)
	if (index < 0 || index >= count) return -1
	const groupStart = lyricGroupStartForIndex(song.lyrics, index, count)
	return times[groupStart]
}

export const currentLyricIndex = computed<number> (() : number => {
	const song = currentSong.value
	const total = song.lyrics.length
	if (total <= 0) return 0
	const times = song.lyricTimes
	// 有时间轴：按当前播放秒数定位（真正的音词同步）
	if (times.length > 0) {
		const d = state.duration > 0 ? state.duration : song.duration
		return timedLyricIndex(song.lyrics, times, total, state.currentTime, d)
	}
	// 无时间轴（纯音乐/上传歌）：退回按进度线性平摊
	const li = Math.floor((state.progress / 100) * total)
	return Math.min(li, total - 1)
})

function safeGetSong(index : number) : Song {
	if (playlist.value.length == 0) return fallbackSong
	if (index < 0 || index >= playlist.value.length) return playlist.value[0]
	return playlist.value[index]
}

function isValidSongIndex(index : number) : boolean {
	return index >= 0 && index < playlist.value.length
}

function normalizePlayMode(mode : string) : PlayMode {
	if (mode == 'repeat-one') return 'repeat-one'
	if (mode == 'shuffle') return 'shuffle'
	return 'sequence'
}

function randomNextSongIndex() : number {
	const len = playlist.value.length
	if (len <= 1) return 0
	let idx = Math.floor(Math.random() * len)
	if (idx == state.currentSongIndex) idx = (idx + 1) % len
	return idx
}

function nextSongIndexForAutoAdvance() : number {
	if (playlist.value.length == 0) return 0
	if (state.playMode == 'repeat-one') return state.currentSongIndex
	if (state.playMode == 'shuffle') return randomNextSongIndex()
	return (state.currentSongIndex + 1) % playlist.value.length
}

function nextSongIndexForManualAdvance() : number {
	if (playlist.value.length == 0) return 0
	if (state.playMode == 'shuffle') return randomNextSongIndex()
	return (state.currentSongIndex + 1) % playlist.value.length
}

function findSongIndexByUrl(url : string) : number {
	for (let i = 0; i < playlist.value.length; i++) {
		if (playlist.value[i].audioUrl == url) return i
	}
	return -1
}

/* ───── 真实数据流：播放统计 ─────
 * totalPlaySeconds 累计有效播放时长（不计 seek 跳跃）
 * moodCounts 按 mood id 累计 → 用于音乐画像计算
 * uniqueSongs 收集听过的歌曲索引 → 用于"听过歌曲数"指标
 */

export type MoodCount = {
	id : string,
	seconds : number
}

export type PlayerStats = {
	totalPlaySeconds : number,
	moodCounts : MoodCount[],
	uniqueSongs : number[],
	hourlyCounts : number[],
	songPlayCount : number[]
}

function makeDefaultStats() : PlayerStats {
	const hourly : number[] = [] as number[]
	for (let i = 0; i < 24; i++) hourly.push(0)
	const songCounts : number[] = [] as number[]
	for (let i = 0; i < playlist.value.length; i++) songCounts.push(0)
	const stats : PlayerStats = {
		totalPlaySeconds: 0,
		moodCounts: [
			{ id: 'sea-salt', seconds: 0 },
			{ id: 'strawberry', seconds: 0 },
			{ id: 'mint', seconds: 0 }
		],
		uniqueSongs: [] as number[],
		hourlyCounts: hourly,
		songPlayCount: songCounts
	}
	return stats
}

function normalizeStats(stats : PlayerStats) : PlayerStats {
	const hourly : number[] = [] as number[]
	for (let i = 0; i < 24; i++) {
		if (stats.hourlyCounts != null && i < stats.hourlyCounts.length) hourly.push(stats.hourlyCounts[i])
		else hourly.push(0)
	}
	const songCounts : number[] = [] as number[]
	for (let i = 0; i < playlist.value.length; i++) {
		if (stats.songPlayCount != null && i < stats.songPlayCount.length) songCounts.push(stats.songPlayCount[i])
		else songCounts.push(0)
	}
	return {
		totalPlaySeconds: stats.totalPlaySeconds,
		moodCounts: stats.moodCounts,
		uniqueSongs: stats.uniqueSongs,
		hourlyCounts: hourly,
		songPlayCount: songCounts
	}
}

/** 同 Bottle：必须用 JSON.parse<PlayerStats> 真类型化，否则 moodCounts.find 会崩 */
function loadPlayerStatsTyped() : PlayerStats {
	const raw = loadStr(K.STATS, '')
	if (raw == '') return makeDefaultStats()
	try {
		const obj = JSON.parse<PlayerStats>(raw)
		return obj == null ? makeDefaultStats() : normalizeStats(obj!)
	} catch (e) {
		return makeDefaultStats()
	}
}

export const playerStats = ref<PlayerStats> (loadPlayerStatsTyped())

let statsDirty = false
let lastStatsSaveAt = 0
function markStatsDirty() {
	statsDirty = true
	const now = Date.now()
	if (now - lastStatsSaveAt > 30000) {
		saveJson(K.STATS, playerStats.value)
		lastStatsSaveAt = now
		statsDirty = false
	}
}

/** 累加 N 秒到 stats，按当前 mood 分配 */
/* 升级事件：每次升级 +1，index 监听后弹庆祝。
 * 只在累计过程中触发，storage 加载历史等级不触发。 */
export const levelUpEvent = ref(0)
export const levelUpTo = ref(1)

const levelThresholds : number[] = [0, 1800, 5400, 12600, 19800, 23400, 27000, 30600, 34200]

function levelFromSeconds(sec : number) : number {
	for (let i = levelThresholds.length - 1; i >= 0; i--) {
		if (sec >= levelThresholds[i]) return i + 1
	}
	return 1
}

function levelBaseSeconds(lv : number) : number {
	if (lv <= 1) return 0
	const idx = lv - 1
	if (idx < levelThresholds.length) return levelThresholds[idx]
	return levelThresholds[levelThresholds.length - 1] + (idx - levelThresholds.length + 1) * 3600
}

function accumulatePlay(seconds : number) {
	if (seconds <= 0) return
	const s = playerStats.value
	const before = s.totalPlaySeconds
	s.totalPlaySeconds += seconds
	const hour = new Date().getHours()
	if (hour >= 0 && hour < s.hourlyCounts.length) s.hourlyCounts[hour] += seconds
	const m = s.moodCounts.find((mc : MoodCount) : boolean => mc.id == state.moodId)
	if (m != null) m!.seconds += seconds
	// 触发响应式更新
	playerStats.value = s
	markStatsDirty()
	// 检测是否跨过等级临界（600 秒整数倍）
	const lvBefore = levelFromSeconds(before)
	const lvAfter = levelFromSeconds(s.totalPlaySeconds)
	if (lvAfter > lvBefore) {
		levelUpTo.value = lvAfter
		levelUpEvent.value = levelUpEvent.value + 1
	}
}

function markSongListened(idx : number) {
	const s = playerStats.value
	if (idx >= 0 && idx < s.songPlayCount.length) {
		s.songPlayCount[idx] += 1
	}
	if (!s.uniqueSongs.includes(idx)) {
		s.uniqueSongs.push(idx)
	}
	playerStats.value = s
	markStatsDirty()
}

/* ───── 派生 computed：等级 / 经验 / 音乐画像 ───── */

export const playerLevel = computed<number> (() : number => {
	return levelFromSeconds(playerStats.value.totalPlaySeconds)
})

/** 当前等级的经验进度，0-100 */
export const levelExpPercent = computed<number> (() : number => {
	const t = playerStats.value.totalPlaySeconds
	const lv = levelFromSeconds(t)
	const base = levelBaseSeconds(lv)
	const next = levelBaseSeconds(lv + 1)
	return ((t - base) / (next - base)) * 100
})

function titleCore(lv : number, moodId : string) : string {
	if (moodId == 'strawberry') {
		if (lv <= 1) return '晚霞试音员'
		if (lv == 2) return '汽水心跳者'
		if (lv == 3) return '黄昏巡游者'
		if (lv < 6) return '珊瑚派对客'
		if (lv < 9) return '日落收藏家'
		return '热浪领航员'
	}
	if (moodId == 'mint') {
		if (lv <= 1) return '薄荷醒梦人'
		if (lv == 2) return '雨林漫步者'
		if (lv == 3) return '清凉调频师'
		if (lv < 6) return '夜风潜行者'
		if (lv < 9) return '绿荫守望者'
		return '瀑布回声师'
	}
	if (lv <= 1) return '浅滩初听者'
	if (lv == 2) return '踏浪新人'
	if (lv == 3) return '海盐巡游者'
	if (lv < 6) return '潮汐旅人'
	if (lv < 9) return '远岸航线家'
	return '海面领航员'
}

export function titleForLevel(lv : number, moodId : string = 'sea-salt') : string {
	return moodLabel(moodId) + ' · LV' + lv + ' · ' + titleCore(lv, moodId)
}

/** 按 moodCounts 实时算音乐画像 */
export const vibeDnasComputed = computed<DnaItem[]> (() : DnaItem[] => {
	const arr = playerStats.value.moodCounts
	let total = 0
	arr.forEach((m : MoodCount) => { total += m.seconds })
	const colors : string[] = ['#60A5FA', '#FB7185', '#4ADE80']
	const names : string[] = ['海风流行', '日落珊瑚', '薄荷电子']
	const result : DnaItem[] = []
	for (let i = 0; i < 3; i++) {
		const pct = total == 0 ? 0 : (arr[i].seconds / total) * 100
		result.push({ name: names[i], percent: Math.round(pct), color: colors[i] })
	}
	return result
})

export const totalPlayMinutes = computed<number> (() : number => Math.floor(playerStats.value.totalPlaySeconds / 60))
export const uniqueSongCount = computed<number> (() : number => playerStats.value.uniqueSongs.length)

export const peakHour = computed<number> (() : number => {
	const arr = playerStats.value.hourlyCounts
	let best = 0
	let bestSeconds = -1
	for (let i = 0; i < arr.length; i++) {
		if (arr[i] > bestSeconds) {
			bestSeconds = arr[i]
			best = i
		}
	}
	return best
})

export const peakHourText = computed<string> (() : string => {
	const h = peakHour.value
	const end = (h + 2) % 24
	const hs = h < 10 ? '0' + h : '' + h
	const es = end < 10 ? '0' + end : '' + end
	return hs + ':00-' + es + ':00'
})

export const topLoopSongs = computed<TopSongItem[]> (() : TopSongItem[] => {
	const result : TopSongItem[] = [] as TopSongItem[]
	const used : number[] = [] as number[]
	for (let rank = 0; rank < 3; rank++) {
		let bestIdx = -1
		let bestCount = -1
		for (let i = 0; i < playerStats.value.songPlayCount.length; i++) {
			if (used.includes(i)) continue
			const count = playerStats.value.songPlayCount[i]
			if (count > bestCount) {
				bestCount = count
				bestIdx = i
			}
		}
		if (bestIdx >= 0 && bestIdx < playlist.value.length && bestCount > 0) {
			used.push(bestIdx)
			const item : TopSongItem = { title: playlist.value[bestIdx].title, count: bestCount }
			result.push(item)
		}
	}
	return result
})

export const dominantMoodId = computed<string> (() : string => {
	const arr = playerStats.value.moodCounts
	let total = 0
	let bestId = ''
	let bestSeconds = -1
	arr.forEach((m : MoodCount) => {
		total += m.seconds
		if (m.seconds > bestSeconds) {
			bestSeconds = m.seconds
			bestId = m.id
		}
	})
	if (total <= 0) return state.moodId == '' ? defaultMoodByTime() : state.moodId
	return bestId == '' ? state.moodId : bestId
})

/** mood id → 中文标签，用于报告卡片 */
export function moodLabel(id : string) : string {
	if (id == 'strawberry') return '日落珊瑚'
	if (id == 'mint') return '薄荷清凉'
	return '海盐微风'
}

export const dominantMoodLabel = computed<string> (() : string => moodLabel(dominantMoodId.value))
export const levelTitle = computed<string> (() : string => titleForLevel(playerLevel.value, dominantMoodId.value))

function dayPart(hour : number) : string {
	if (hour >= 5 && hour < 11) return 'morning'
	if (hour >= 17 && hour < 21) return 'evening'
	return 'night'
}

function makeSpiritAnimal(name : string, desc : string, color : string) : SpiritAnimal {
	const animal : SpiritAnimal = {
		name: name,
		desc: desc,
		color: color
	}
	return animal
}

export const spiritAnimal = computed<SpiritAnimal> (() : SpiritAnimal => {
	const part = dayPart(peakHour.value)
	const mood = dominantMoodId.value
	if (mood == 'strawberry' && part == 'morning') return makeSpiritAnimal('晨光里的火烈鸟', '热烈来得很早，连清晨也带着一点粉色。', '#FF8577')
	if (mood == 'strawberry' && part == 'evening') return makeSpiritAnimal('黄昏的火烈鸟', '你把心动留给晚霞，也把节拍留给热风。', '#FF6B6B')
	if (mood == 'strawberry') return makeSpiritAnimal('霓虹边的狐', '夜色越深，你越擅长把孤独听成光。', '#FB7185')
	if (mood == 'mint' && part == 'morning') return makeSpiritAnimal('瀑布池的鹿', '你喜欢清醒的绿意，脚步轻，耳朵也轻。', '#22C55E')
	if (mood == 'mint' && part == 'evening') return makeSpiritAnimal('雨后窗边的猫', '你把降温后的城市，听成一小段柔软呼吸。', '#10B981')
	if (mood == 'mint') return makeSpiritAnimal('雨林夜歌的萤', '越安静的夜里，你越会发出自己的光。', '#34D399')
	if (part == 'morning') return makeSpiritAnimal('海面初醒的鸥', '你总能在第一阵风里，找到重新开始的理由。', '#38BDF8')
	if (part == 'evening') return makeSpiritAnimal('落日航线的鲸', '你的夏天辽阔而慢，适合把余温一路带走。', '#60A5FA')
	return makeSpiritAnimal('深夜潮汐的鲸', '你在浪声里整理世界，也在夜色里保持自由。', '#2563EB')
})

/** 报告一句话文案，按主导 mood + 时长生成 */
export const reportTagline = computed<string> (() : string => {
	const mins = totalPlayMinutes.value
	if (mins <= 0) return '夏天才刚刚开始，先听一首歌吧。'
	const id = dominantMoodId.value
	if (id == 'strawberry') return '你的夏天是黄昏色的，温柔又漫长。'
	if (id == 'mint') return '你的夏天泛着薄荷光，清凉又安静。'
	return '你的夏天有海盐的味道，自由又辽阔。'
})

function hasListenedSong(index : number) : boolean {
	return playerStats.value.uniqueSongs.includes(index)
}

function pushSongIfMissing(list : Song[], song : Song) {
	const exists = list.find((s : Song) : boolean => s.title == song.title && s.artist == song.artist)
	if (exists == null) list.push(song)
}

export const personalizedPlaylist = computed<Song[]> (() : Song[] => {
	const moodId = dominantMoodId.value
	const result : Song[] = []
	const listened : Song[] = []
	playlist.value.forEach((song : Song, idx : number) => {
		if (song.moodId != moodId) return
		if (hasListenedSong(idx) && playlist.value.length > 3) {
			listened.push(song)
		} else {
			pushSongIfMissing(result, song)
		}
	})
	playlist.value.forEach((song : Song, idx : number) => {
		if (song.moodId == moodId) return
		if (hasListenedSong(idx) && playlist.value.length > 3) {
			listened.push(song)
		} else {
			pushSongIfMissing(result, song)
		}
	})
	listened.forEach((song : Song) => {
		pushSongIfMissing(result, song)
	})
	return result
})

/* ───── 真实音频引擎 ─────
 * uts 的 `any` 实际是 Kotlin Any? 不允许属性访问，需要类型化。
 * 用 uni-app x 暴露的 InnerAudioContext 类型，可空指针。
 */
let audio : InnerAudioContext | null = null
let audioInited = false
let lastAudioTime = 0 // 用于累计有效播放时长（屏蔽 seek 跳跃）
let audioErrorSkipCount = 0
// 当前已加载到 audio 的曲目下标。-1 = 尚未加载任何曲目。
// 用数值下标判断"是否换歌"，而非比较 audio.src 字符串——
// 原生层 src getter 在部分 ROM 会返回规范化绝对路径，字符串比较会恒不等，
// 导致暂停后再播放被误判为换歌而从头重载。
let loadedSongIndex = -1

function ensureAudio() {
	if (audioInited) return
	audioInited = true
	const ctx = uni.createInnerAudioContext()
	ctx.volume = state.volume
	ctx.autoplay = false

	ctx.onCanplay(() => {
		const d = ctx.duration
		if (d > 0) state.duration = d
		state.audioLoading = false
		state.audioErrorMessage = ''
	})

	ctx.onTimeUpdate(() => {
		const cur = ctx.currentTime
		const dur = ctx.duration
		state.currentTime = cur   // 驱动歌词时间轴同步
		if (dur > 0) {
			state.duration = dur
			state.progress = (cur / dur) * 100
		}
		// 累计有效时长（差值 < 2 秒视为正常播放，否则当 seek 跳过）
		const diff = cur - lastAudioTime
		if (diff > 0 && diff < 2) {
			accumulatePlay(diff)
		}
		lastAudioTime = cur
	})

	ctx.onPlay(() => {
		state.isPlaying = true
		state.audioLoading = false
		state.audioErrorMessage = ''
		audioErrorSkipCount = 0
	})
	ctx.onPause(() => { state.isPlaying = false })
	ctx.onStop(() => { state.isPlaying = false })
	// 中途缓冲：网络卡顿时音频拉流，置 loading 让 vinyl 显示缓冲反馈
	ctx.onWaiting(() => { state.audioLoading = true })

	ctx.onEnded(() => {
		state.audioLoading = false
		if (state.playMode == 'repeat-one') {
			state.progress = 0
			state.currentTime = 0
			playSongByResolvedIndex(state.currentSongIndex)
		} else if (state.autoPlayNext) {
			state.progress = 0
			state.currentTime = 0
			playSongByResolvedIndex(nextSongIndexForAutoAdvance())
		} else {
			state.progress = 100
			if (state.duration > 0) state.currentTime = state.duration
			state.isPlaying = false
		}
	})

	ctx.onError((err) => {
		// 不显式标注参数类型，让 uts 从 onError 签名推断（类型名因版本而异，标注反而易编译失败）
		// 打印原生层真实错误码 + 描述，定位播放失败原因
		console.error('[audio] onError errCode=' + err.errCode + ' errMsg=' + err.errMsg + ' src=' + ctx.src)
		handleAudioError()
	})

	audio = ctx
}

function loadCurrentSong(autoplay : boolean) {
	ensureAudio()
	if (audio == null) return
	const song = safeGetSong(state.currentSongIndex)
	if (song.audioUrl == '') {
		console.warn('[audio] loadCurrentSong: audioUrl 为空, idx=' + state.currentSongIndex)
		state.isPlaying = false
		state.audioLoading = false
		state.audioErrorMessage = '当前没有可播放的音频'
		uni.showToast({ title: state.audioErrorMessage, icon: 'none' })
		return
	}
	console.log('[audio] loadCurrentSong idx=' + state.currentSongIndex + ' autoplay=' + autoplay + ' src=' + song.audioUrl)
	audio!.src = song.audioUrl
	loadedSongIndex = state.currentSongIndex
	state.progress = 0
	state.currentTime = 0
	state.duration = 0
	state.audioErrorMessage = ''
	state.audioLoading = autoplay
	lastAudioTime = 0
	if (isValidSongIndex(state.currentSongIndex)) {
		markSongListened(state.currentSongIndex)
	}
	if (autoplay) {
		audio!.play()
	}
}

function handleAudioError() {
	state.isPlaying = false
	state.audioLoading = false
	state.audioErrorMessage = '当前音频加载失败'
	if (playlist.value.length <= 1 || audioErrorSkipCount >= playlist.value.length - 1) {
		audioErrorSkipCount = 0
		uni.showToast({ title: '音频加载失败，请稍后再试', icon: 'none' })
		return
	}
	audioErrorSkipCount++
	uni.showToast({ title: '当前音频加载失败，已为你跳到下一首', icon: 'none' })
	nextSong()
}

export function togglePlay() {
	ensureAudio()
	if (audio == null) return
	if (playlist.value.length == 0) {
		state.audioErrorMessage = '暂无可播放歌曲'
		uni.showToast({ title: state.audioErrorMessage, icon: 'none' })
		return
	}
	// 用已加载下标判断是否需要换歌：未加载过、或当前曲目下标变了，才重新 load
	if (loadedSongIndex != state.currentSongIndex) {
		loadCurrentSong(true)
		return
	}
	if (state.isPlaying) {
		audio!.pause()
	} else {
		audio!.play()
	}
}

/** 当前背景色（RGB ref），由 mood 切换驱动，平滑过渡 */
const initialMood = moods.find((m : Mood) : boolean => m.id == state.moodId)
export const bgColor : Ref<RGB> = ref(hexToRgb(initialMood == null ? moods[0].bg : initialMood!.bg))

export function setMood(id : string) {
	const next = moods.find((m : Mood) : boolean => m.id == id)
	if (next == null) return
	state.moodId = id
	tweenColor(bgColor, next!.bg, 800)
	saveStr(K.MOOD, id)
}

export function playSong(index : number) {
	if (!isValidSongIndex(index)) {
		state.audioErrorMessage = '歌曲不存在'
		uni.showToast({ title: state.audioErrorMessage, icon: 'none' })
		return
	}
	audioErrorSkipCount = 0
	state.currentSongIndex = index
	state.activePageIndex = 0
	saveNum(K.SONG_INDEX, index)
	pushRecent(playlist.value[index].title)
	loadCurrentSong(true)
}

function playSongByResolvedIndex(index : number) {
	if (!isValidSongIndex(index)) {
		state.isPlaying = false
		state.audioLoading = false
		state.audioErrorMessage = '暂无可播放歌曲'
		return
	}
	audioErrorSkipCount = 0
	state.currentSongIndex = index
	saveNum(K.SONG_INDEX, state.currentSongIndex)
	pushRecent(playlist.value[state.currentSongIndex].title)
	loadCurrentSong(true)
}

function syncStatsSongSlots() {
	const s = playerStats.value
	while (s.songPlayCount.length < playlist.value.length) s.songPlayCount.push(0)
	if (s.songPlayCount.length > playlist.value.length) s.songPlayCount.length = playlist.value.length
	playerStats.value = s
	markStatsDirty()
}

export function addUserSong(input : UserSongInput) : boolean {
	const url = input.audioUrl.trim()
	console.log('[upload] addUserSong url=' + url)
	if (url == '') {
		console.warn('[upload] addUserSong: url 为空')
		uni.showToast({ title: '没有拿到音频文件', icon: 'none' })
		return false
	}
	const title = normalizeUserSongTitle(input.title)
	const exists = userSongs.value.find((song : Song) : boolean => song.audioUrl == url)
	if (exists != null) {
		console.log('[upload] addUserSong: 该 url 已存在，直接播放已有条目')
		const existingIdx = findSongIndexByUrl(url)
		if (existingIdx >= 0) playSong(existingIdx)
		return true
	}
	const song : Song = {
		title: title,
		artist: '本地上传',
		cover: '',
		fallbackImage: '/static/images/fallback-sea.svg',
		audioUrl: url,
		moodId: state.moodId == '' ? 'sea-salt' : state.moodId,
		lyrics: ['这是你上传的音乐', '让夏天按你的节奏来', '本地旋律正在播放'],
		lyricTimes: [] as number[],
		duration: 0
	}
	// 必须 push（追加到末尾）而非 unshift：songPlayCount / uniqueSongs 按 playlist
	// 下标存储，syncStatsSongSlots 在末尾补 0。若 unshift，已有用户歌下标整体后移，
	// 统计会张冠李戴。push 保证已有下标稳定。
	const arr = userSongs.value.slice()
	arr.push(song)
	userSongs.value = arr
	saveUserSongs()
	syncStatsSongSlots()
	const idx = findSongIndexByUrl(url)
	console.log('[upload] addUserSong: 已加入 playlist, idx=' + idx + ' playlist.length=' + playlist.value.length)
	if (idx >= 0) playSong(idx)
	else console.warn('[upload] addUserSong: 加入后竟找不到下标，url=' + url)
	uni.showToast({ title: '音乐已添加', icon: 'none' })
	return true
}

/** 删除上传文件的物理文件（仅删我们复制进 USER_DATA_PATH 的；content:// 等外部 URI 跳过） */
function deleteAudioFile(path : string) {
	if (!path.startsWith('unifile://') && !path.startsWith('file://')) {
		console.log('[upload] 非本地复制文件，跳过物理删除: ' + path)
		return
	}
	try {
		const fs = uni.getFileSystemManager()
		fs.unlinkSync(path)
		console.log('[upload] 已删除物理文件 ' + path)
	} catch (e) {
		console.warn('[upload] 删除物理文件失败 ' + path + ' err=' + e)
	}
}

/** 删除一首上传歌曲：物理文件 + 元数据 + 统计索引重映射 + 当前播放下标修正 */
export function removeUserSong(audioUrl : string) : boolean {
	const ui = userSongs.value.findIndex((s : Song) : boolean => s.audioUrl == audioUrl)
	if (ui < 0) return false
	// 用户歌在 playlist 中的下标 = base 段长度 + 它在 userSongs 中的下标
	const pi = basePlaylist.length + ui

	// 1. 删物理文件
	deleteAudioFile(audioUrl)

	// 2. 若正在播放被删曲，先停
	if (state.currentSongIndex == pi && audio != null) {
		audio!.stop()
		state.isPlaying = false
		state.progress = 0
		state.duration = 0
		loadedSongIndex = -1
	}

	// 3. 从 userSongs 移除并重建 playlist
	const arr = userSongs.value.slice()
	arr.splice(ui, 1)
	userSongs.value = arr
	saveUserSongs()

	// 4. 修正统计索引（按 playlist 下标存储，删中间项需整体重映射，不能简单 append/clamp）
	const s = playerStats.value
	if (pi >= 0 && pi < s.songPlayCount.length) s.songPlayCount.splice(pi, 1)
	const remapped : number[] = [] as number[]
	s.uniqueSongs.forEach((idx : number) => {
		if (idx == pi) return                       // 被删曲：丢弃
		remapped.push(idx > pi ? idx - 1 : idx)     // 其后的曲：下标 -1
	})
	s.uniqueSongs = remapped
	playerStats.value = s
	markStatsDirty()

	// 5. 修正当前播放下标 / 已加载下标
	if (state.currentSongIndex > pi) {
		state.currentSongIndex = state.currentSongIndex - 1
		if (loadedSongIndex > pi) loadedSongIndex = loadedSongIndex - 1
	} else if (state.currentSongIndex == pi) {
		if (state.currentSongIndex >= playlist.value.length) {
			state.currentSongIndex = playlist.value.length > 0 ? playlist.value.length - 1 : 0
		}
		loadedSongIndex = -1
	}
	saveNum(K.SONG_INDEX, state.currentSongIndex)
	uni.showToast({ title: '已删除', icon: 'none' })
	return true
}

/** 重命名一首上传歌曲（仅改标题，不影响下标/文件） */
export function renameUserSong(audioUrl : string, newTitle : string) : boolean {
	const t = normalizeUserSongTitle(newTitle)
	if (t == '') {
		uni.showToast({ title: '名字不能为空', icon: 'none' })
		return false
	}
	let found = false
	const arr = userSongs.value.map((song : Song) : Song => {
		if (song.audioUrl != audioUrl) return song
		found = true
		return {
			title: t,
			artist: song.artist,
			cover: song.cover,
			fallbackImage: song.fallbackImage,
			audioUrl: song.audioUrl,
			moodId: song.moodId,
			lyrics: song.lyrics,
			lyricTimes: song.lyricTimes,
			duration: song.duration
		}
	})
	if (!found) return false
	userSongs.value = arr
	saveUserSongs()
	uni.showToast({ title: '已重命名', icon: 'none' })
	return true
}

export function nextSong() {
	if (playlist.value.length == 0) {
		state.isPlaying = false
		state.audioLoading = false
		state.audioErrorMessage = '暂无可播放歌曲'
		uni.showToast({ title: state.audioErrorMessage, icon: 'none' })
		return
	}
	playSongByResolvedIndex(nextSongIndexForManualAdvance())
}

export function prevSong() {
	if (playlist.value.length == 0) {
		state.isPlaying = false
		state.audioLoading = false
		state.audioErrorMessage = '暂无可播放歌曲'
		uni.showToast({ title: state.audioErrorMessage, icon: 'none' })
		return
	}
	state.currentSongIndex = (state.currentSongIndex - 1 + playlist.value.length) % playlist.value.length
	saveNum(K.SONG_INDEX, state.currentSongIndex)
	pushRecent(playlist.value[state.currentSongIndex].title)
	loadCurrentSong(true)
}

export function setAutoPlayNext(enabled : boolean) {
	state.autoPlayNext = enabled
	saveStr(K.AUTO_NEXT, enabled ? '1' : '0')
}

export function setPlayMode(mode : PlayMode) {
	const next = normalizePlayMode(mode)
	state.playMode = next
	saveStr(K.PLAY_MODE, next)
}

export function setVolume(v : number, persist : boolean = true) {
	let vv = v
	if (vv < 0) vv = 0
	if (vv > 1) vv = 1
	state.volume = vv
	if (audio != null) audio!.volume = vv
	// 拖拽过程中 persist=false，只改内存/音量；松手时再落盘一次，避免每帧写 storage
	if (persist) saveNum(K.VOLUME, vv)
}

/** percent 0-100，立即同步到 audio.currentTime */
export function seekTo(percent : number) {
	let p = percent
	if (p < 0) p = 0
	if (p > 100) p = 100
	state.progress = p
	if (state.duration > 0) state.currentTime = (p / 100) * state.duration  // 立即同步歌词位置
	if (audio != null && state.duration > 0 && currentSong.value.audioUrl != '') {
		audio!.seek((p / 100) * state.duration)
	}
}

/** progress-bar 拖拽时调用：仅本地显示进度，不调 audio.seek */
export function previewSeek(percent : number) {
	let p = percent
	if (p < 0) p = 0
	if (p > 100) p = 100
	state.progress = p
	if (state.duration > 0) state.currentTime = (p / 100) * state.duration
}

/** 拖拽开始：记录原 isPlaying 并暂停 */
let dragWasPlaying = false
export function beginSeekDrag() {
	if (audio == null) return
	dragWasPlaying = state.isPlaying
	if (dragWasPlaying) audio!.pause()
}

/** 拖拽结束：commit 到 audio，恢复之前的播放状态 */
export function endSeekDrag() {
	if (audio == null || state.duration <= 0) return
	if (currentSong.value.audioUrl == '') return
	audio!.seek((state.progress / 100) * state.duration)
	if (dragWasPlaying && currentSong.value.audioUrl != '') audio!.play()
}

export function seekToLyric(index : number) {
	const song = currentSong.value
	const times = song.lyricTimes
	// 有时间轴：点歌词跳到该行对应秒数
	if (times.length > 0 && state.duration > 0) {
		const targetTime = lyricSeekTime(song, index, state.duration)
		if (targetTime >= 0) {
			seekTo((targetTime / state.duration) * 100)
			return
		}
	}
	const total = song.lyrics.length
	if (total <= 0) return
	seekTo((index / total) * 100)
}

export function addBottle(message : string) : boolean {
	const text = normalizeBottleText(message)
	if (text == '') {
		uni.showToast({ title: '先写点想说的话吧', icon: 'none' })
		return false
	}
	const bottle : Bottle = {
		id: nextBottleId(),
		message: text,
		songTitle: currentSong.value.title,
		createdAt: Date.now(),
		replies: [] as string[]
	}
	const arr = bottles.value.slice()
	arr.unshift(bottle)
	bottles.value = arr
	saveBottles()
	uni.showToast({ title: '漂流瓶已投出', icon: 'none' })
	return true
}

export function addBottleReply(id : number, reply : string) : boolean {
	const text = normalizeBottleText(reply)
	if (text == '') {
		uni.showToast({ title: '先写一封回信吧', icon: 'none' })
		return false
	}
	let updated = false
	const arr = bottles.value.map((b : Bottle) : Bottle => {
		if (b.id != id) return b
		updated = true
		const nextReplies = b.replies.slice()
		nextReplies.push(text)
		return {
			id: b.id,
			message: b.message,
			songTitle: b.songTitle,
			createdAt: b.createdAt,
			replies: nextReplies
		}
	})
	if (!updated) return false
	bottles.value = arr
	saveBottles()
	const active = state.activeBottle
	if (active != null && active!.id == id) {
		const latest = bottles.value.find((b : Bottle) : boolean => b.id == id)
		if (latest != null) state.activeBottle = latest!
	}
	uni.showToast({ title: '回信已送达', icon: 'none' })
	return true
}

export function openBottle(b : Bottle) {
	state.activeBottle = b
}

export function closeBottle() {
	state.activeBottle = null
}

/* ───── 白噪音混音器 ───── */
export type AmbientTrack = {
	id : string,
	name : string,
	iconName : string,
	audioUrl : string,
	on : boolean,
	volume : number,
	loading : boolean,
	error : boolean
}

export type AmbientPrefs = {
	id : string,
	on : boolean,
	volume : number
}

/**
 * 环境混音真实自然录音，来源：Wikimedia Commons
 * - wave.ogg   : "Oceanwavescrushing.ogg" Kalundborg Fjord 海浪，CC BY 3.0 (uploader: jeppen)
 * - cicada.ogg : "Tanna japonensis v01.ogg" 日本蜩（Higurashi）蝉鸣，CC BY 4.0 (uploader: Σ64)
 * - rain-natural.mp3 : "Bourne woods rain 2020-05-10 0800" 森林雨声实录，CC BY-SA 4.0 (uploader: Robert EA Harvey)。
 * 替换原先的合成电音 .wav 占位。
 */
const defaultAmbients : AmbientTrack[] = [
	{ id: 'wave',   name: '海浪', iconName: 'wave', audioUrl: '/static/audio/wave.ogg',   on: false, volume: 0.45, loading: false, error: false },
	{ id: 'cicada', name: '夏蝉', iconName: 'cicada', audioUrl: '/static/audio/cicada.ogg', on: false, volume: 0.35, loading: false, error: false },
	{ id: 'rain',   name: '微雨', iconName: 'rain', audioUrl: '/static/audio/rain-natural.mp3', on: false, volume: 0.38, loading: false, error: false }
]

function loadAmbientPrefsTyped() : AmbientPrefs[] {
	const raw = loadStr(K.AMBIENTS, '')
	if (raw == '') return [] as AmbientPrefs[]
	try {
		const arr = JSON.parseArray<AmbientPrefs>(raw)
		return arr == null ? [] as AmbientPrefs[] : arr
	} catch (e) {
		return [] as AmbientPrefs[]
	}
}

function makeInitialAmbients() : AmbientTrack[] {
	const saved = loadAmbientPrefsTyped()
	return defaultAmbients.map((track : AmbientTrack) : AmbientTrack => {
		const pref = saved.find((p : AmbientPrefs) : boolean => p.id == track.id)
		if (pref == null) return track
		return {
			id: track.id,
			name: track.name,
			iconName: track.iconName,
			audioUrl: track.audioUrl,
			on: pref!.on,
			volume: pref!.volume,
			loading: false,
			error: false
		}
	})
}

export const ambients = ref<AmbientTrack[]> (makeInitialAmbients())

const ambientContexts : Map<string, InnerAudioContext> = new Map()

function saveAmbientPrefs() {
	const prefs : AmbientPrefs[] = ambients.value.map((track : AmbientTrack) : AmbientPrefs => {
		return { id: track.id, on: track.on, volume: track.volume }
	})
	saveJson(K.AMBIENTS, prefs)
}

function updateAmbient(id : string, patch : AmbientTrack) {
	ambients.value = ambients.value.map((track : AmbientTrack) : AmbientTrack => {
		return track.id == id ? patch : track
	})
}

function findAmbient(id : string) : AmbientTrack | null {
	const found = ambients.value.find((track : AmbientTrack) : boolean => track.id == id)
	return found == null ? null : found!
}

function ensureAmbientAudio(track : AmbientTrack) : InnerAudioContext {
	const existing = ambientContexts.get(track.id)
	if (existing != null) return existing!
	const ctx = uni.createInnerAudioContext()
	ctx.src = track.audioUrl
	ctx.loop = true
	ctx.autoplay = false
	ctx.volume = track.volume
	ctx.onPlay(() => {
		const latest = findAmbient(track.id)
		if (latest == null) return
		updateAmbient(track.id, {
			id: latest!.id,
			name: latest!.name,
			iconName: latest!.iconName,
			audioUrl: latest!.audioUrl,
			on: true,
			volume: latest!.volume,
			loading: false,
			error: false
		})
	})
	ctx.onCanplay(() => {
		const latest = findAmbient(track.id)
		if (latest == null) return
		updateAmbient(track.id, {
			id: latest!.id,
			name: latest!.name,
			iconName: latest!.iconName,
			audioUrl: latest!.audioUrl,
			on: latest!.on,
			volume: latest!.volume,
			loading: false,
			error: false
		})
	})
	ctx.onError(() => {
		const latest = findAmbient(track.id)
		if (latest == null) return
		updateAmbient(track.id, {
			id: latest!.id,
			name: latest!.name,
			iconName: latest!.iconName,
			audioUrl: latest!.audioUrl,
			on: false,
			volume: latest!.volume,
			loading: false,
			error: true
		})
		saveAmbientPrefs()
		uni.showToast({ title: latest!.name + '加载失败', icon: 'none' })
	})
	ambientContexts.set(track.id, ctx)
	return ctx
}

export const showMixer = ref(false)

export function toggleMixer() {
	showMixer.value = !showMixer.value
}

export function toggleAmbient(id : string) {
	const track = findAmbient(id)
	if (track == null) return
	const nextOn = !track!.on
	const nextTrack : AmbientTrack = {
		id: track!.id,
		name: track!.name,
		iconName: track!.iconName,
		audioUrl: track!.audioUrl,
		on: nextOn,
		volume: track!.volume,
		loading: nextOn,
		error: false
	}
	updateAmbient(id, nextTrack)
	const ctx = ensureAmbientAudio(nextTrack)
	ctx.volume = nextTrack.volume
	if (nextOn) {
		ctx.play()
	} else {
		ctx.pause()
		updateAmbient(id, {
			id: nextTrack.id,
			name: nextTrack.name,
			iconName: nextTrack.iconName,
			audioUrl: nextTrack.audioUrl,
			on: false,
			volume: nextTrack.volume,
			loading: false,
			error: false
		})
	}
	saveAmbientPrefs()
}

export function setAmbientVolume(id : string, volume : number) {
	const track = findAmbient(id)
	if (track == null) return
	let v = volume
	if (v < 0) v = 0
	if (v > 1) v = 1
	const nextTrack : AmbientTrack = {
		id: track!.id,
		name: track!.name,
		iconName: track!.iconName,
		audioUrl: track!.audioUrl,
		on: track!.on,
		volume: v,
		loading: track!.loading,
		error: track!.error
	}
	updateAmbient(id, nextTrack)
	const ctx = ambientContexts.get(id)
	if (ctx != null) ctx!.volume = v
	saveAmbientPrefs()
}

export function resumeActiveAmbients() {
	ambients.value.forEach((track : AmbientTrack) => {
		if (!track.on) return
		const ctx = ensureAmbientAudio(track)
		ctx.volume = track.volume
		ctx.play()
	})
}
