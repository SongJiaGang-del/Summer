	.mask {
		position: fixed;
		left: 0; right: 0; top: 0; bottom: 0;
		background-color: rgba(0, 0, 0, 0.5);
		align-items: center;
		justify-content: center;
		padding-left: 28px;
		padding-right: 28px;
		z-index: 150;
	}
	.card {
		width: 100%;
		border-radius: 44px;
		padding: 36px;
		align-items: center;
		background-color: #1B4965;
	}
	.brand {
		font-size: 11px;
		color: rgba(255, 255, 255, 0.6);
		letter-spacing: 3px;
		margin-bottom: 24px;
	}
	.hero {
		align-items: center;
		margin-bottom: 28px;
	}
	.hero-lv {
		font-size: 56px;
		font-weight: bold;
		color: #ffffff;
	}
	.hero-title {
		font-size: 18px;
		font-weight: bold;
		color: #AEEFF0;
		letter-spacing: 4px;
		margin-top: 6px;
	}
	.stats {
		flex-direction: row;
		justify-content: space-between;
		width: 100%;
		margin-bottom: 28px;
	}
	.stat {
		flex: 1;
		align-items: center;
	}
	.stat-val {
		font-size: 18px;
		font-weight: bold;
		color: #ffffff;
	}
	.stat-label {
		font-size: 9px;
		color: rgba(255, 255, 255, 0.5);
		margin-top: 6px;
		letter-spacing: 1px;
	}
	.tagline {
		font-size: 13px;
		color: rgba(255, 255, 255, 0.9);
		text-align: center;
		line-height: 22px;
		margin-bottom: 18px;
	}
	.hint {
		font-size: 9px;
		color: rgba(255, 255, 255, 0.4);
		letter-spacing: 1px;
		margin-bottom: 24px;
	}
	.close-btn {
		width: 100%;
		padding-top: 16px;
		padding-bottom: 16px;
		border-radius: 999px;
		background-color: rgba(255, 255, 255, 0.92);
		align-items: center;
	}
	.close-text {
		font-size: 12px;
		font-weight: bold;
		color: #1B4965;
		letter-spacing: 3px;
	}
</style>
