<template>
	<view class="scene-page" :style="pageStyle">
		<view class="status-bar" :style="statusBarStyle"></view>

		<view class="topbar">
			<view class="back-btn" @click="onBack">
				<icon-prev :size="22" color="#1B4965"></icon-prev>
			</view>
			<text class="top-title">场景歌单</text>
			<view class="top-spacer"></view>
		</view>

		<scroll-view class="content" :scroll-y="true">
			<view v-if="sceneFound" class="hero">
				<view class="hero-image">
					<image-fallback :src="scene.image" :fallbackSrc="scene.fallbackImage" mode="aspectFill"></image-fallback>
				</view>
				<view class="hero-shade"></view>
				<view class="hero-copy">
					<view class="time-chip">
						<text class="time-chip-text">{{ scene.suggestedHour }}</text>
					</view>
					<text class="scene-name">{{ scene.name }}</text>
					<text class="scene-narrative">{{ scene.narrative }}</text>
					<text class="scene-desc">{{ scene.desc }}</text>
				</view>
			</view>

			<view v-else class="missing">
				<text class="missing-title">这扇传送门暂时走丢了</text>
				<text class="missing-desc">返回发现页，换一个场景试试看。</text>
			</view>

			<view v-if="sceneFound" class="songs-section">
				<text class="section-title">为这个场景漂来的歌</text>
				<view v-if="sceneSongs.length > 0" class="grid">
					<album-card
						v-for="(song, idx) in sceneSongs"
						:key="song.title"
						:title="song.title"
						:artist="song.artist"
						:cover="song.cover"
						v-bind:fallback-image="song.fallbackImage"
						v-bind:duration="song.duration"
						v-bind:delay="120 + idx * 80"
						@play="onPlaySceneSong(song)">
					</album-card>
				</view>
				<view v-else class="empty">
					<text class="empty-title">这个场景还没有歌</text>
					<text class="empty-desc">先回发现页听一首为你漂来的歌吧。</text>
				</view>
			</view>
		</scroll-view>
	</view>
</template>

<script setup lang="uts">
	import { ref, computed, onMounted } from 'vue'
	import { onLoad } from '@dcloudio/uni-app'
	import {
		categories, playlist, setMood, playSong,
		type Category, type Song
	} from '@/store/player.uts'
	import { hexToRgb, rgbToCss } from '@/utils/color.uts'
	import IconPrev from '@/components/icons/icon-prev.uvue'

	const sceneId = ref('')
	const statusBarH = ref(0)
	const statusBarStyle = computed<string>(() : string => 'height:' + statusBarH.value + 'px')

	const fallbackScene : Category = {
		id: '',
		name: '未知场景',
		image: '',
		fallbackImage: '/static/images/fallback-sea.svg',
		moodId: 'sea-salt',
		desc: '',
		narrative: '',
		suggestedHour: '--:--',
		songIndices: [] as number[]
	}

	const scene = computed<Category>(() : Category => {
		const found = categories.find((cat : Category) : boolean => cat.id == sceneId.value)
		return found != null ? found! : fallbackScene
	})

	const sceneFound = computed<boolean>(() : boolean => {
		return categories.find((cat : Category) : boolean => cat.id == sceneId.value) != null
	})

	const pageStyle = computed<string>(() : string => {
		const mood = scene.value.moodId
		if (mood == 'strawberry') return 'background-color:' + rgbToCss(hexToRgb('#FFD1BB'))
		if (mood == 'mint') return 'background-color:' + rgbToCss(hexToRgb('#E8F5E9'))
		return 'background-color:' + rgbToCss(hexToRgb('#E0F7FA'))
	})

	function pushSceneSong(list : Song[], song : Song) {
		const exists = list.find((s : Song) : boolean => s.title == song.title && s.artist == song.artist)
		if (exists == null) list.push(song)
	}

	function getSongsForScene(cat : Category) : Song[] {
		const result : Song[] = []
		cat.songIndices.forEach((idx : number) => {
			if (idx >= 0 && idx < playlist.value.length) pushSceneSong(result, playlist.value[idx])
		})
		if (result.length == 0) return playlist.value
		return result
	}

	const sceneSongs = computed<Song[]>(() : Song[] => {
		return getSongsForScene(scene.value)
	})

	function findSongIndex(song : Song) : number {
		for (let i = 0; i < playlist.value.length; i++) {
			const s = playlist.value[i]
			if (s.title == song.title && s.artist == song.artist) return i
		}
		return -1
	}

	function goBackToIndex() {
		uni.navigateBack({
			fail: () => {
				uni.redirectTo({ url: '/pages/index/index' })
			}
		})
	}

	function onPlaySceneSong(song : Song) {
		const idx = findSongIndex(song)
		if (idx < 0) return
		playSong(idx)
		goBackToIndex()
	}

	function onBack() {
		goBackToIndex()
	}

	onMounted(() => {
		const info = uni.getSystemInfoSync()
		statusBarH.value = info.statusBarHeight as number
	})

	onLoad((query : OnLoadOptions) => {
		const id = query['sceneId'] as string | null
		if (id != null) {
			sceneId.value = id!
			const found = categories.find((cat : Category) : boolean => cat.id == sceneId.value)
			if (found != null) setMood(found!.moodId)
		}
	})
</script>

