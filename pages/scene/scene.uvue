	.scene-page {
		flex: 1;
		flex-direction: column;
	}
	.topbar {
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		padding-left: 20px;
		padding-right: 20px;
		padding-top: 12px;
		padding-bottom: 16px;
	}
	.back-btn {
		width: 40px;
		height: 40px;
		border-radius: 999px;
		background-color: rgba(255, 255, 255, 0.34);
		border-width: 1px;
		border-color: rgba(255, 255, 255, 0.46);
		align-items: center;
		justify-content: center;
	}
	.top-title {
		font-size: 16px;
		font-weight: bold;
		color: #1B4965;
		letter-spacing: 3px;
	}
	.top-spacer {
		width: 40px;
		height: 40px;
	}
	.content {
		flex: 1;
	}
	.hero {
		height: 620rpx;
		margin-left: 24px;
		margin-right: 24px;
		border-radius: 48px;
		overflow: hidden;
		position: relative;
	}
	.hero-image {
		width: 100%;
		height: 100%;
	}
	.hero-shade {
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		height: 70%;
		background-color: rgba(0, 0, 0, 0.42);
	}
	.hero-copy {
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		padding: 28px;
	}
	.scene-name {
		font-size: 28px;
		font-weight: bold;
		color: #ffffff;
		letter-spacing: 4px;
	}
	.time-chip {
		align-self: flex-start;
		padding-left: 12px;
		padding-right: 12px;
		padding-top: 6px;
		padding-bottom: 6px;
		border-radius: 999px;
		background-color: rgba(255, 255, 255, 0.22);
		margin-bottom: 12px;
	}
	.time-chip-text {
		font-size: 11px;
		font-weight: bold;
		color: #ffffff;
		letter-spacing: 2px;
	}
	.scene-narrative {
		font-size: 13px;
		color: rgba(255, 255, 255, 0.92);
		line-height: 22px;
		margin-top: 10px;
		font-weight: bold;
	}
	.scene-desc {
		font-size: 12px;
		color: rgba(255, 255, 255, 0.76);
		line-height: 22px;
		margin-top: 12px;
	}
	.songs-section {
		padding-left: 24px;
		padding-right: 24px;
		padding-top: 28px;
		padding-bottom: 220px;
	}
	.section-title {
		font-size: 12px;
		font-weight: bold;
		color: rgba(27, 73, 101, 0.55);
		letter-spacing: 2px;
		margin-bottom: 14px;
	}
	.grid {
		flex-direction: row;
		flex-wrap: wrap;
		justify-content: space-between;
	}
	.missing,
	.empty {
		margin: 24px;
		padding: 32px;
		border-radius: 36px;
		background-color: rgba(255, 255, 255, 0.28);
		border-width: 1px;
		border-color: rgba(255, 255, 255, 0.42);
		align-items: center;
	}
	.missing-title,
	.empty-title {
		font-size: 15px;
		font-weight: bold;
		color: #1B4965;
	}
	.missing-desc,
	.empty-desc {
		font-size: 11px;
		color: rgba(27, 73, 101, 0.48);
		margin-top: 8px;
		line-height: 18px;
	}
</style>
